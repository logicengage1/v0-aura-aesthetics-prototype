# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
# For the deployed site, set these same variables in your host's
# environment-variable settings.

# Anthropic API key — powers the AI concierge chat widget (app/api/chat).
# Get one at https://console.anthropic.com (billing must be funded).
ANTHROPIC_API_KEY=
