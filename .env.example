# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
# For the deployed site, set these same variables in Netlify:
#   Site settings → Environment variables.

# Anthropic API key — powers the AI concierge chat widget (app/api/chat).
# Get one at https://console.anthropic.com (billing must be funded).
ANTHROPIC_API_KEY=

# Airtable — server-side lead logging from the chat route (app/api/chat).
# Personal Access Token with data.records:read + data.records:write on the base.
AIRTABLE_TOKEN=
AIRTABLE_BASE=appqdYlMxxCqmmIyZ
AIRTABLE_TABLE=Bookings
